# ══════════════════════════════════════════════════════════
# Comités SST: COPASST y COCOLAB (Actas digitales)
#
# Reutiliza tablas existentes:
#   • Miembros Comite SST  → asistentes (FK)
#   • Programación Capacitaciones → capacitaciones COPASST (FK)
# Tablas nuevas (con prefijo copasst_/cocolab_/compromisos):
#   • copasst_actas, copasst_condiciones_inseguras
#   • cocolab_actas, cocolab_acciones_preventivas
#   • compromisos (compartida — discriminador COMITE)
#
# IMPORTANTE: estas variables NO usan prefijo AIRTABLE_
# ══════════════════════════════════════════════════════════

# ── COPASST: Actas (cabecera) ──────────────────────────────
COPASST_ACTAS_TABLE_ID=tbl_xxx
COPASST_ACTAS_ID_FIELD=fld_xxx
COPASST_ACTAS_NUMERO_ACTA_FIELD=fld_xxx
COPASST_ACTAS_MES_EVALUADO_FIELD=
COPASST_ACTAS_FECHA_REUNION_FIELD=
COPASST_ACTAS_HORA_INICIO_FIELD=
COPASST_ACTAS_HORA_CIERRE_FIELD=
COPASST_ACTAS_LUGAR_FIELD=
COPASST_ACTAS_ACCIDENTES_FIELD=
COPASST_ACTAS_ACCIDENTES_DETALLE_FIELD=
COPASST_ACTAS_INCIDENTES_FIELD=
COPASST_ACTAS_INCIDENTES_DETALLE_FIELD=
COPASST_ACTAS_NOVEDADES_FIELD=
COPASST_ACTAS_ESTADO_FIELD=
COPASST_ACTAS_FIRMA_PRESIDENTE_FIELD=
COPASST_ACTAS_FIRMA_SECRETARIO_FIELD=
COPASST_ACTAS_URL_DOCUMENTO_FIELD=
COPASST_ACTAS_FECHA_EXPORT_FIELD=
COPASST_ACTAS_ASISTENTES_LINK_FIELD=
COPASST_ACTAS_CAPACITACIONES_LINK_FIELD=
COPASST_ACTAS_CONDICIONES_LINK_FIELD=
COPASST_ACTAS_COMPROMISOS_LINK_FIELD=
COPASST_ACTAS_CREATED_AT_FIELD=
COPASST_ACTAS_UPDATED_AT_FIELD=

# ── COPASST: Condiciones inseguras ─────────────────────────
COPASST_CONDICIONES_TABLE_ID=tbl_xxx
COPASST_CONDICIONES_ID_FIELD=fld_xxx
COPASST_CONDICIONES_ACTA_LINK_FIELD=
COPASST_CONDICIONES_DESCRIPCION_FIELD=
COPASST_CONDICIONES_RESULTADO_FIELD=
COPASST_CONDICIONES_OBSERVACION_FIELD=

# ── COCOLAB: Actas (cabecera) ──────────────────────────────
COCOLAB_ACTAS_TABLE_ID=tbl_xxx
COCOLAB_ACTAS_ID_FIELD=fld_xxx
COCOLAB_ACTAS_NUMERO_ACTA_FIELD=fld_xxx
COCOLAB_ACTAS_MES_EVALUADO_FIELD=
COCOLAB_ACTAS_FECHA_REUNION_FIELD=
COCOLAB_ACTAS_HORA_INICIO_FIELD=
COCOLAB_ACTAS_HORA_CIERRE_FIELD=
COCOLAB_ACTAS_LUGAR_FIELD=
COCOLAB_ACTAS_QUEJAS_ACOSO_FIELD=
COCOLAB_ACTAS_QUEJAS_DETALLE_FIELD=
COCOLAB_ACTAS_CONFLICTOS_FIELD=
COCOLAB_ACTAS_CONFLICTOS_DETALLE_FIELD=
COCOLAB_ACTAS_ESTADO_FIELD=
COCOLAB_ACTAS_FIRMA_PRESIDENTE_FIELD=
COCOLAB_ACTAS_FIRMA_SECRETARIA_FIELD=
COCOLAB_ACTAS_URL_DOCUMENTO_FIELD=
COCOLAB_ACTAS_FECHA_EXPORT_FIELD=
COCOLAB_ACTAS_ASISTENTES_LINK_FIELD=
COCOLAB_ACTAS_ACCIONES_LINK_FIELD=
COCOLAB_ACTAS_COMPROMISOS_LINK_FIELD=
COCOLAB_ACTAS_CREATED_AT_FIELD=
COCOLAB_ACTAS_UPDATED_AT_FIELD=

# ── COCOLAB: Acciones preventivas ──────────────────────────
COCOLAB_ACCIONES_TABLE_ID=tbl_xxx
COCOLAB_ACCIONES_ID_FIELD=fld_xxx
COCOLAB_ACCIONES_ACTA_LINK_FIELD=
COCOLAB_ACCIONES_CATEGORIA_FIELD=
COCOLAB_ACCIONES_DESCRIPCION_FIELD=

# ── Compromisos (TABLA COMPARTIDA — COPASST + COCOLAB) ─────
# Discriminador: campo COMITE (singleSelect: COPASST|COCOLAB)
COMPROMISOS_TABLE_ID=tbl_xxx
COMPROMISOS_ID_FIELD=fld_xxx
COMPROMISOS_COMITE_FIELD=
COMPROMISOS_ACTA_COPASST_LINK_FIELD=
COMPROMISOS_ACTA_COCOLAB_LINK_FIELD=
COMPROMISOS_DESCRIPCION_FIELD=
COMPROMISOS_RESPONSABLE_FIELD=
COMPROMISOS_FECHA_LIMITE_FIELD=
COMPROMISOS_CUMPLIDO_FIELD=

# ── Miembros Comite SST (TABLA EXISTENTE — solo lectura) ───
# IDs reales pre-cargados (provistos por el equipo)
MIEMBROS_COMITE_TABLE_ID=tbl_xxx
MIEMBROS_COMITE_ID_FIELD=
MIEMBROS_COMITE_NOMBRE_FIELD=fld_xxx
MIEMBROS_COMITE_CEDULA_FIELD=
MIEMBROS_COMITE_CARGO_FIELD=
MIEMBROS_COMITE_COMITE_FIELD=fld_xxx
MIEMBROS_COMITE_ROL_FIELD=
MIEMBROS_COMITE_ESTADO_FIELD=
# Opcionales (dejar vacío si no existen):
MIEMBROS_COMITE_EMPLEADO_CORE_FIELD=
MIEMBROS_COMITE_REPRESENTACION_FIELD=
MIEMBROS_COMITE_FECHA_INICIO_FIELD=
MIEMBROS_COMITE_FECHA_FIN_FIELD=

# ── Asistencia Comites (TABLA INTERMEDIA — asistencia + firma) ─
# Compartida entre COPASST y COCOLAB (discriminador: COMITE)
# Reemplaza el uso directo de ASISTENTES_LINK en actas
ASISTENCIA_COMITES_TABLE_ID=
ASISTENCIA_COMITES_ID_FIELD=
ASISTENCIA_COMITES_ACTA_COPASST_LINK_FIELD=
ASISTENCIA_COMITES_ACTA_COCOLAB_LINK_FIELD=
ASISTENCIA_COMITES_MIEMBRO_LINK_FIELD=
ASISTENCIA_COMITES_COMITE_FIELD=
ASISTENCIA_COMITES_ASISTIO_FIELD=
ASISTENCIA_COMITES_FIRMA_FIELD=
ASISTENCIA_COMITES_FECHA_FIRMA_FIELD=
ASISTENCIA_COMITES_OBSERVACIONES_FIELD=

